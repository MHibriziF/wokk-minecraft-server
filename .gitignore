.env
!.env.example

# Server runtime/downloaded files (not world data)
.data/cache
.data/logs/
.data/libraries/
.data/versions/
.data/*.jar
.data/usercache.json
.data/.rcon-cli.*

# Fabric auto-generated cache (re-created on server start)
.data/.fabric/processedMods/

# Downloaded server jars (fetched by Fabric installer, not user-managed)
.data/.fabric/server/

# Runtime lock file
.data/world/session.lock

# OS
Thumbs.db
desktop.ini
.DS_Store

*.log